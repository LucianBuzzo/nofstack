{
  "name": "nofstack",
  "version": "1.0.0",
  "description": "Fortran backed blogging engine",
  "main": "server.js",
  "scripts": {
    "test": "npm run test:syntax",
    "start": "node server.js",
    "watch": "gulp build && gulp watch",
    "test:syntax": "node --check server.js && node --check gulpfile.js"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "gulp": "^3.9.0",
    "gulp-copy": "0.0.2"
  },
  "nofstack": {
    "mainIn": [
      "src/lib/string_functions.f95",
      "src/markdown.f95",
      "src/readfile.f95",
      "src/menu.f95",
      "src/content.f95",
      "src/templates.f95",
      "src/index.f95"
    ],
    "mainOut": "build"
  },
  "eslintConfig": {
    "env": {
      "es6": true,
      "browser": true,
      "node": true
    }
  },
  "dependencies": {
    "express": "^4.13.3"
  }
